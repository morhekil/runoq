#!/usr/bin/env bash

set -euo pipefail

SELF_PATH="$0"
while [[ -L "$SELF_PATH" ]]; do
  SELF_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
  SELF_PATH="$(readlink "$SELF_PATH")"
  [[ "$SELF_PATH" = /* ]] || SELF_PATH="${SELF_DIR}/${SELF_PATH}"
done

AGENDEV_ROOT="$(cd "$(dirname "$SELF_PATH")/.." && pwd)"
export AGENDEV_ROOT
export AGENDEV_CONFIG="${AGENDEV_CONFIG:-$AGENDEV_ROOT/config/agendev.json}"

source "$AGENDEV_ROOT/scripts/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  agendev init
  agendev plan <file>
  agendev run [--issue N] [--dry-run]
  agendev report <summary|issue|cost> [...]
  agendev maintenance
EOF
}

prepare_target_context() {
  export TARGET_ROOT
  export REPO
  TARGET_ROOT="$(agendev::target_root)"
  REPO="$(agendev::repo)"
  export PATH="$AGENDEV_ROOT/scripts:$PATH"
}

prepare_auth() {
  eval "$("$AGENDEV_ROOT/scripts/gh-auth.sh" export-token)"
}

claude_exec() {
  local claude_bin="${AGENDEV_CLAUDE_BIN:-claude}"
  command -v "$claude_bin" >/dev/null 2>&1 || agendev::die "Claude CLI not found: $claude_bin"
  "$claude_bin" "$@"
}

run_subcommand() {
  prepare_target_context
  prepare_auth
  claude_exec --agent github-orchestrator --add-dir "$AGENDEV_ROOT" -- "$@"
}

plan_subcommand() {
  local plan_file
  [[ $# -eq 1 ]] || agendev::die "Usage: agendev plan <file>"
  prepare_target_context
  prepare_auth
  plan_file="$(agendev::absolute_path "$1")"
  [[ -f "$plan_file" ]] || agendev::die "Plan file not found: $plan_file"
  claude_exec --skill plan-to-issues --add-dir "$AGENDEV_ROOT" -- "$plan_file"
}

maintenance_subcommand() {
  prepare_target_context
  prepare_auth
  claude_exec --agent maintenance-reviewer --add-dir "$AGENDEV_ROOT"
}

subcommand="${1:-}"
shift || true

case "$subcommand" in
  init)
    prepare_target_context
    "$AGENDEV_ROOT/scripts/setup.sh" "$@"
    ;;
  plan)
    plan_subcommand "$@"
    ;;
  run)
    run_subcommand "$@"
    ;;
  report)
    prepare_target_context
    "$AGENDEV_ROOT/scripts/report.sh" "$@"
    ;;
  maintenance)
    maintenance_subcommand "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
