#!/usr/bin/env bash

set -euo pipefail

SELF_PATH="$0"
while [[ -L "$SELF_PATH" ]]; do
  SELF_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
  SELF_PATH="$(readlink "$SELF_PATH")"
  [[ "$SELF_PATH" = /* ]] || SELF_PATH="${SELF_DIR}/${SELF_PATH}"
done

RUNOQ_ROOT="$(cd "$(dirname "$SELF_PATH")/.." && pwd)"
export RUNOQ_ROOT
export RUNOQ_CONFIG="${RUNOQ_CONFIG:-$RUNOQ_ROOT/config/runoq.json}"

implementation="${RUNOQ_IMPLEMENTATION:-runtime}"
if [[ -n "$implementation" && "$implementation" != "runtime" ]]; then
  echo "runoq: Unknown RUNOQ_IMPLEMENTATION: $implementation (expected runtime)" >&2
  exit 1
fi

runtime_bin="${RUNOQ_RUNTIME_BIN:-}"
if [[ -n "$runtime_bin" ]]; then
  exec "$runtime_bin" "$@"
fi

go_bin="${RUNOQ_GO_BIN:-go}"
command -v "$go_bin" >/dev/null 2>&1 || {
  echo "runoq: Go toolchain not found: $go_bin" >&2
  exit 1
}

bin="$RUNOQ_ROOT/.cache/runoq-runtime"
(cd "$RUNOQ_ROOT" && "$go_bin" build -o "$bin" ./cmd/runoq-runtime)
exec "$bin" "$@"
