#!/usr/bin/env bash

set -euo pipefail

if [[ -n "${FAKE_RUNTIME_PLAN_CLAUDE_LOG:-}" ]]; then
  printf '%s\n' "$*" >>"$FAKE_RUNTIME_PLAN_CLAUDE_LOG"
fi

case " $* " in
  *" --agent milestone-decomposer "*)
    cat <<'EOF'
{"type":"assistant","message":{"content":[{"type":"text","text":"<!-- runoq:payload:milestone-decomposer -->\n```json\n{\"items\":[{\"key\":\"runtime-milestone\",\"type\":\"implementation\",\"title\":\"Runtime milestone\",\"goal\":\"Ship runtime compatibility flow\",\"criteria\":[\"compatibility task exists\"],\"scope\":[\"runtime\"],\"sequencing_rationale\":\"Needed before execution\",\"priority\":1}],\"warnings\":[]}\n```"}]}}
{"type":"result","result":"done"}
EOF
    ;;
  *" --agent task-decomposer "*)
    cat <<'EOF'
{"type":"assistant","message":{"content":[{"type":"text","text":"<!-- runoq:payload:task-decomposer -->\n```json\n{\"items\":[{\"key\":\"runtime-task\",\"type\":\"task\",\"title\":\"Runtime task\",\"body\":\"Body\",\"priority\":1,\"estimated_complexity\":\"medium\",\"complexity_rationale\":\"Runtime parity scaffold\",\"depends_on_keys\":[]}],\"warnings\":[]}\n```"}]}}
{"type":"result","result":"done"}
EOF
    ;;
  *)
    echo "unexpected agent invocation: $*" >&2
    exit 1
    ;;
esac
